# Dokploy staging environment template
# Copy values to Dokploy env/secrets (do not commit real credentials)
# Use INTERNAL service hostnames for DB/MinIO (not public Traefik URLs, not container IPs)

# RAILS_ENV=staging loads config/environments/staging.rb; aligns HelloAsso (sandbox) + staging CORS.
RAILS_ENV=staging
APP_ENV=staging
DEPLOY_ENV=staging
DB_BOOT_TASK=prepare

# Optional: force HelloAsso sandbox API (HelloassoService; redundant if RAILS_ENV=staging and credentials helloasso.environment: sandbox)
# HELLOASSO_USE_SANDBOX=true

# Optional: public staging domain suffix for CORS (e.g. mestryx.dev), same as host in the URL without https://
# STAGING_PUBLIC_DOMAIN=mestryx.dev
# Optional for JS tooling. Keep only if needed by your runtime scripts.
# NODE_ENV=staging
RAILS_LOG_LEVEL=info
TZ=Europe/Paris
PORT=3000

# Force HTTPS behavior behind Dokploy proxy
RAILS_FORCE_SSL=true

# Mail links (optional)
# Keep commented if managed via Rails credentials/defaults.
# MAILER_HOST=staging.grenoble-roller.org
# MAILER_PROTOCOL=https

# Rails credentials decryption key (secret)
RAILS_MASTER_KEY=__SET_IN_DOKPLOY_SECRET__

# PostgreSQL (prefer DATABASE_URL as a secret)
DATABASE_URL=postgresql://__USER__:__PASSWORD__@__POSTGRES_INTERNAL_HOST__:5432/__DB_NAME__

# Optional explicit DB vars (if needed)
DATABASE_HOST=__POSTGRES_INTERNAL_HOST__
DATABASE_PORT=5432
DATABASE_USER=__USER__
DATABASE_PASSWORD=__PASSWORD__
DATABASE_NAME=__DB_NAME__

# Solid Queue in Puma (single-process mode)
SOLID_QUEUE_IN_PUMA=true

# MinIO/S3-compatible storage (internal endpoint)
# Example: http://minio:9000 or Dokploy internal hostname for MinIO service
MINIO_ENDPOINT=http://__MINIO_INTERNAL_HOST__:9000
MINIO_ACCESS_KEY_ID=__MINIO_ACCESS_KEY__
MINIO_SECRET_ACCESS_KEY=__MINIO_SECRET_KEY__
# After first deploy with MINIO_* set: cd /rails && bundle exec rake minio:ensure_bucket (creates grenoble-roller-staging if missing)
