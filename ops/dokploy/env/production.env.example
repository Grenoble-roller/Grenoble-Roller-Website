# Dokploy production environment template
# Copy values to Dokploy env/secrets (do not commit real credentials)
# Use INTERNAL service hostnames for DB/MinIO (not public Traefik URLs, not container IPs)

RAILS_ENV=production
APP_ENV=production
DEPLOY_ENV=production
DB_BOOT_TASK=migrate

# Optional: force HelloAsso live API if credentials still say sandbox (normally APP_ENV+DEPLOY_ENV above are enough)
# HELLOASSO_USE_PRODUCTION=true

# Optional for JS tooling. Keep only if needed by your runtime scripts.
# NODE_ENV=production
RAILS_LOG_LEVEL=info
TZ=Europe/Paris
PORT=3000

# Force HTTPS behavior behind Dokploy proxy
RAILS_FORCE_SSL=true

# Mail links (optional)
# Keep commented if managed via Rails credentials/defaults.
# MAILER_HOST=grenoble-roller.org
# MAILER_PROTOCOL=https

# Rails credentials decryption key (secret)
RAILS_MASTER_KEY=__SET_IN_DOKPLOY_SECRET__

# PostgreSQL (prefer DATABASE_URL as a secret)
DATABASE_URL=postgresql://__USER__:__PASSWORD__@__POSTGRES_INTERNAL_HOST__:5432/__DB_NAME__

# Optional explicit DB vars (if needed)
DATABASE_HOST=__POSTGRES_INTERNAL_HOST__
DATABASE_PORT=5432
DATABASE_USER=__USER__
DATABASE_PASSWORD=__PASSWORD__
DATABASE_NAME=__DB_NAME__

# Solid Queue in Puma (single-process mode)
SOLID_QUEUE_IN_PUMA=true

# S3-compatible storage — SeaweedFS (internal endpoint, port 8333)
# Use the Dokploy internal service hostname (not the public Traefik URL)
S3_ENDPOINT=http://__SEAWEEDFS_INTERNAL_HOST__:8333
S3_ACCESS_KEY_ID=__S3_ACCESS_KEY__
S3_SECRET_ACCESS_KEY=__S3_SECRET_KEY__
# Bucket auto-created at first boot via storage:ensure_bucket (called by docker-entrypoint)
