<% content_for :title, 'Événements Grenoble Roller' %>
<% content_for :description, "Découvrez tous les événements Roller à Grenoble. Randonnées urbaines, cours d'initiation, événements à thème. Rejoignez la communauté et participez aux sorties !" %>

<section class="banner-page mb-4">
  <div class="banner-overlay"></div>
  <div class="banner-content">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 text-center">
          <i class="bi bi-calendar-event banner-icon-small mb-2" aria-hidden="true"></i>
          <h1 class="banner-title-page mb-3">Nos Événements</h1>
          <p class="banner-subtitle-page mb-4">
            Découvrez toutes nos sorties roller
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="container pb-5">
  <!-- Filtres -->
  <div class="card card-liquid mb-4">
    <div class="card-body p-3 p-md-4">
      <%= form_with url: events_path, method: :get, local: true, class: "row g-3 align-items-end", data: { turbo: false } do |f| %>
        <!-- Filtre Route -->
        <div class="col-12 col-md-4">
          <%= f.label :route_id, "Parcours", class: "form-label fw-semibold small mb-1" %>
          <%= f.select :route_id, 
              options_from_collection_for_select(@routes, :id, :name, params[:route_id]),
              { include_blank: "Tous les parcours" },
              { class: "form-select form-select-sm" } %>
        </div>

        <!-- Filtre Niveau -->
        <div class="col-12 col-md-4">
          <%= f.label :level, "Niveau", class: "form-label fw-semibold small mb-1" %>
          <%= f.select :level,
              options_for_select(@levels, params[:level]),
              { include_blank: "Tous les niveaux" },
              { class: "form-select form-select-sm" } %>
        </div>

        <!-- Boutons -->
        <div class="col-12 col-md-4">
          <div class="d-flex gap-2">
            <%= f.submit "Filtrer", class: "btn btn-liquid-primary btn-sm flex-grow-1" %>
            <% if params[:route_id].present? || params[:level].present? %>
              <%= link_to events_path, class: "btn btn-outline-secondary btn-sm" do %>
                <i class="bi bi-x-lg" aria-hidden="true"></i>
              <% end %>
            <% end %>
          </div>
        </div>

        <!-- Conserver les paramètres de pagination si présents -->
        <%= hidden_field_tag :page_past, params[:page_past] if params[:page_past].present? %>
      <% end %>
    </div>
  </div>

  <div id="events-upcoming" class="mb-5">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between mb-3">
      <div>
        <h2 class="h2 fw-bold mb-1"><i class="bi bi-stars me-2" aria-hidden="true"></i>À venir</h2>
        <p class="text-body-secondary mb-0">
          Les prochains rendez-vous roller ouverts à la communauté.
        </p>
      </div>
      <span class="badge badge-liquid-primary fs-6"><%= pluralize(@upcoming_events.size, "événement", "événements") %></span>
    </div>

    <% if @upcoming_events.any? %>
      <div class="event-grid">
        <div class="row g-4">
          <% @upcoming_events.each_with_index do |event, index| %>
            <%= render 'events/event_card',
                       event: event,
                       render_signup_button: true,
                       current_user: current_user,
                       is_first: (index == 0) %>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="card card-liquid border-liquid shadow-sm">
        <div class="card-body p-4 p-md-5 text-center">
          <i class="bi bi-calendar-x fs-1 text-muted mb-3 d-block" aria-hidden="true"></i>
          <h3 class="h5 fw-bold mb-3">Aucun événement à venir</h3>
          
          <% if user_signed_in? %>
            <% if policy(Event).create? %>
              <p class="text-body-secondary mb-4">
                Il n'y a pas encore d'événement planifié. En tant qu'organisateur, vous pouvez créer le premier événement !
              </p>
              <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
                <%= link_to new_event_path, class: "btn btn-liquid-primary" do %>
                  <i class="bi bi-plus-circle me-2" aria-hidden="true"></i>Créer un événement
                <% end %>
                <%= link_to initiations_path, class: "btn btn-outline-primary" do %>
                  <i class="bi bi-mortarboard me-2" aria-hidden="true"></i>Voir les initiations
                <% end %>
              </div>
            <% else %>
              <p class="text-body-secondary mb-4">
                Aucun événement n'est prévu pour le moment. Revenez bientôt pour découvrir nos prochaines sorties !
              </p>
              <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
                <%= link_to initiations_path, class: "btn btn-liquid-primary" do %>
                  <i class="bi bi-mortarboard me-2" aria-hidden="true"></i>Voir les initiations
                <% end %>
                <%= link_to about_path, class: "btn btn-outline-secondary" do %>
                  <i class="bi bi-info-circle me-2" aria-hidden="true"></i>En savoir plus sur l'association
                <% end %>
              </div>
            <% end %>
          <% else %>
            <p class="text-body-secondary mb-4">
              Aucun événement n'est prévu pour le moment. Connectez-vous pour être informé des prochaines sorties !
            </p>
            <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
              <%= link_to new_user_session_path, class: "btn btn-liquid-primary" do %>
                <i class="bi bi-box-arrow-in-right me-2" aria-hidden="true"></i>Se connecter
              <% end %>
              <%= link_to initiations_path, class: "btn btn-outline-primary" do %>
                <i class="bi bi-mortarboard me-2" aria-hidden="true"></i>Voir les initiations
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div id="events-past">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between mb-3">
      <div>
        <h2 class="h2 fw-bold mb-1"><i class="bi bi-archive me-2" aria-hidden="true"></i>Événements passés</h2>
        <p class="text-body-secondary mb-0">
          Un aperçu des dernières sorties et initiations organisées.
        </p>
      </div>
      <% if @pagy_past.count > 0 %>
        <span class="badge badge-liquid-secondary fs-6"><%= pluralize(@pagy_past.count, "événement", "événements") %></span>
      <% end %>
    </div>

    <% if @past_events.any? %>
      <!-- Tableau des événements passés -->
      <div class="card card-liquid">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Titre</th>
                  <th>Parcours</th>
                  <th>Niveau</th>
                  <th>Distance</th>
                  <th>Participants</th>
                  <th>Prix</th>
                  <th>Statut</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% @past_events.each do |event| %>
                  <tr>
                    <td data-label="Date">
                      <div class="d-flex flex-column">
                        <span class="fw-semibold"><%= event.start_at.strftime("%d/%m/%Y") %></span>
                        <small class="text-muted"><%= event.start_at.strftime("%H:%M") %></small>
                      </div>
                    </td>
                    <td data-label="Titre">
                      <div class="d-flex align-items-center">
                        <% if event.cover_image.attached? %>
                          <%= image_tag rails_representation_path(event.cover_image_banner), class: "rounded me-2", style: "width: 71px; height: 40px; object-fit: cover;", alt: event.title %>
                        <% end %>
                        <span class="fw-semibold"><%= event.title %></span>
                      </div>
                    </td>
                    <td data-label="Parcours">
                      <%= event.route&.name || "-" %>
                    </td>
                    <td data-label="Niveau">
                      <% case event.level %>
                      <% when "beginner" %>
                        <span class="badge bg-info">Débutant</span>
                      <% when "intermediate" %>
                        <span class="badge bg-primary">Intermédiaire</span>
                      <% when "advanced" %>
                        <span class="badge bg-warning">Confirmé</span>
                      <% when "all_levels" %>
                        <span class="badge bg-secondary">Tous niveaux</span>
                      <% end %>
                    </td>
                    <td data-label="Distance">
                      <%= event.distance_km %> km
                    </td>
                    <td data-label="Participants">
                      <% if event.unlimited? %>
                        <span class="text-muted">Illimité</span>
                      <% else %>
                        <%= event.attendances_count %> / <%= event.max_participants %>
                      <% end %>
                    </td>
                    <td data-label="Prix">
                      <%= format_event_price(event.price_cents) %>
                    </td>
                    <td data-label="Statut">
                      <% if event.canceled? %>
                        <span class="badge bg-danger">Annulé</span>
                      <% else %>
                        <span class="badge bg-success">Terminé</span>
                      <% end %>
                    </td>
                    <td data-label="Actions">
                      <%= link_to event_path(event), class: "btn btn-sm btn-outline-primary" do %>
                        <i class="bi bi-eye me-1" aria-hidden="true"></i>Voir
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
      <!-- Pagination événements passés -->
      <% if @pagy_past.pages > 1 %>
        <div class="mt-4 d-flex justify-content-center">
          <%== pagy_bootstrap_nav(@pagy_past) %>
        </div>
      <% end %>
    <% else %>
      <div class="card card-liquid border-liquid shadow-sm">
        <div class="card-body p-4 p-md-5 text-center">
          <i class="bi bi-archive fs-1 text-muted mb-3 d-block" aria-hidden="true"></i>
          <h3 class="h5 fw-bold mb-3">Aucun événement passé</h3>
          <p class="text-body-secondary mb-4">
            Les événements passés apparaîtront ici une fois qu'ils auront eu lieu.
          </p>
          <% if user_signed_in? && policy(Event).create? %>
            <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
              <%= link_to new_event_path, class: "btn btn-outline-primary" do %>
                <i class="bi bi-plus-circle me-2" aria-hidden="true"></i>Créer un événement
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
