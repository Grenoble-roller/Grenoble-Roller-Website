<% 
  # Calculs pour les stats
  personal_memberships = @memberships.select { |m| !m.is_child_membership? }
  children_memberships = @memberships.select { |m| m.is_child_membership? }
  # Séparation : essais gratuits vs paiements en attente
  children_trial = children_memberships.select { |m| m.trial? }
  children_pending = children_memberships.select { |m| m.pending? && m.total_amount_cents > 0 }
  children_paid = children_memberships.select { |m| !m.pending? && !m.trial? && m.status != 'expired' }
  active_memberships = @memberships.select { |m| m.active? }
  pending_memberships = @memberships.select { |m| m.pending? }
  expired_memberships = @memberships.select { |m| m.expired? }
  total_paid = @memberships.select { |m| !m.pending? }.sum(&:total_amount_cents) / 100.0
  
  # Date d'expiration la plus proche
  nearest_expiry = @memberships.select { |m| m.active? && m.end_date.present? }
    .map(&:end_date).compact.min

  # Profil parent complet pour pouvoir ajouter un enfant (sécurité côté vue + contrôleur)
  parent_profile_complete_for_child = current_user.child_profile_complete_for_membership?
%>


<div class="container py-4">
  <!-- HERO SECTION -->
  <div class="hero-memberships">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
      <div>
        <h1 class="h2 mb-2">
          <i class="bi bi-person-badge me-2 fs-2"></i>
          <% if current_user.has_active_children_memberships? %>
            Mes adhésions
          <% else %>
            Mon adhésion
          <% end %>
        </h1>
        <p class="mb-2 opacity-75" style="font-style: italic;">
          Gérez vos adhésions et celles de vos enfants
        </p>
        <div class="d-flex align-items-center gap-3 flex-wrap mt-3">
          <span class="badge bg-white text-dark px-3 py-2" style="font-size: 0.875rem;">
            <i class="bi bi-calendar-event me-1"></i>
            Saison <%= @season %>
          </span>
          <span class="badge bg-white text-dark px-3 py-2" style="font-size: 0.875rem;">
            <i class="bi bi-calendar-range me-1"></i>
            <%= l(@start_date, format: :short) %> → <%= l(@end_date, format: :short) %>
          </span>
        </div>
      </div>
      <% if @memberships.empty? %>
        <div class="mt-3 mt-md-0">
          <%= link_to new_membership_path(type: 'adult'), class: "btn btn-light btn-lg" do %>
            <i class="bi bi-person-plus me-2"></i>Adhérer maintenant
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- LAYOUT 2 COLONNES -->
  <div class="row">
    <!-- SIDEBAR GAUCHE (Desktop) -->
    <div class="col-12 col-lg-4 mb-4 mb-lg-0">
      <div class="sidebar-sticky">
        <!-- Quick Actions -->
        <div class="card card-liquid shadow-sm mb-4">
          <div class="card-body">
            <h3 class="h6 mb-3">
              <i class="bi bi-lightning-charge text-liquid-primary me-2"></i>
              Actions rapides
            </h3>
            
            <!-- Adhérer pour moi -->
            <% unless @active_membership %>
              <%= link_to new_membership_path(type: 'adult'), class: "text-decoration-none" do %>
                <div class="quick-action-card teal">
                  <div class="d-flex align-items-center mb-2">
                    <i class="bi bi-person-badge fs-3 text-liquid-primary me-3"></i>
                    <div class="flex-grow-1">
                      <h4 class="h6 mb-0 fw-bold">J'adhère</h4>
                      <small class="text-muted">
                        <% if @pending_membership %>
                          Adhésion en attente
                        <% else %>
                          Pas d'adhésion active
                        <% end %>
                      </small>
                    </div>
                  </div>
                </div>
              <% end %>
            <% end %>
            
            <!-- Ajouter un enfant -->
            <%= link_to new_membership_path(type: 'child'), class: "text-decoration-none", data: { turbo: false } do %>
              <div class="quick-action-card orange">
                <div class="d-flex align-items-center mb-2">
                  <i class="bi bi-person-plus fs-3 text-liquid-warning me-3"></i>
                  <div class="flex-grow-1">
                    <h4 class="h6 mb-0 fw-bold">Ajouter un enfant</h4>
                    <small class="text-muted">
                      <% if parent_profile_complete_for_child %>
                        <% if children_trial.any? || children_pending.any? %>
                          <%= children_trial.count + children_pending.count %> à finaliser
                        <% else %>
                          Inscrire un enfant
                        <% end %>
                      <% else %>
                        Complétez d'abord votre profil (nom, prénom, téléphone, adresse, code postal, ville, date de naissance)
                      <% end %>
                    </small>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Overview Stats -->
        <% if @memberships.any? %>
          <div class="card card-liquid shadow-sm mb-4">
            <div class="card-body">
              <h3 class="h6 mb-3">
                <i class="bi bi-graph-up text-liquid-primary me-2"></i>
                Vue d'ensemble
              </h3>
              
              <div class="d-flex flex-column gap-2">
                <% if active_memberships.any? %>
                  <div class="memberships-stats-item">
                    <span><i class="bi bi-check-circle text-success me-2"></i>Actives</span>
                    <strong><%= active_memberships.count %></strong>
                  </div>
                <% end %>
                
                <% if pending_memberships.any? %>
                  <div class="memberships-stats-item">
                    <span><i class="bi bi-hourglass-split text-warning me-2"></i>En attente</span>
                    <strong><%= pending_memberships.count %></strong>
                  </div>
                <% end %>
                
                <% if nearest_expiry %>
                  <div class="memberships-stats-item">
                    <span><i class="bi bi-calendar-x text-info me-2"></i>Expire le</span>
                    <strong><%= l(nearest_expiry, format: :short) %></strong>
                  </div>
                <% end %>
                
                <% if total_paid > 0 %>
                  <div class="memberships-stats-item">
                    <span><i class="bi bi-currency-euro text-primary me-2"></i>Total payé</span>
                    <strong><%= number_to_currency(total_paid, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></strong>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Description -->
        <div class="card card-liquid shadow-sm">
          <div class="card-body">
            <p class="small text-muted mb-0">
              <i class="bi bi-info-circle me-2"></i>
              <strong>En adhérent à notre association vous soutenez notre volonté de faire découvrir le roller à tous. 
              Vous aidez à l'organisation de nos traditionnelles randonnées roller pour le plus grand plaisir 
              des grenoblois qui aiment la glisse !</strong>
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- COLONNE DROITE : CONTENU PRINCIPAL -->
    <div class="col-12 col-lg-8">
      <% if @memberships.empty? %>
        <!-- EMPTY STATE AMÉLIORÉ -->
        <div class="empty-state-modern">
          <div class="empty-state-header">
            <div class="empty-state-icon">🎉</div>
            <h2 class="empty-state-title">Rejoignez Grenoble Roller !</h2>
            <p class="empty-state-subtitle">
              Devenez membre et profitez des avantages exclusifs de l'association
            </p>
          </div>
          
          <div class="empty-state-benefits">
            <div class="benefit-item">
              <div class="benefit-icon">
                <i class="bi bi-people-fill"></i>
              </div>
              <span class="benefit-text">Rejoindre une communauté passionnée</span>
            </div>
            <div class="benefit-item">
              <div class="benefit-icon">
                <i class="bi bi-heart-fill"></i>
              </div>
              <span class="benefit-text">Soutenir l'association et ses projets</span>
            </div>
            <div class="benefit-item">
              <div class="benefit-icon">
                <i class="bi bi-book-fill"></i>
              </div>
              <span class="benefit-text">Participer aux initiations roller</span>
            </div>
            <div class="benefit-item">
              <div class="benefit-icon">
                <i class="bi bi-tag-fill"></i>
              </div>
              <span class="benefit-text">Réduction sur les t-shirts et goodies</span>
            </div>
          </div>
          
          <div class="empty-state-cta">
            <%= link_to new_membership_path(type: 'adult'), class: "btn btn-liquid-primary btn-lg btn-cta-modern" do %>
              <i class="bi bi-person-plus me-2"></i>Adhérer maintenant
              <i class="bi bi-arrow-right ms-2"></i>
            <% end %>
          </div>
        </div>
      <% else %>
        <!-- ADHÉSION PERSONNELLE -->
        <% if personal_memberships.any? %>
          <% personal_memberships.each do |membership| %>
            <%= render partial: 'membership_card_improved', locals: { membership: membership, is_child: false } %>
          <% end %>
        <% end %>

        <!-- ADHÉSIONS ENFANTS -->
        <% if children_memberships.any? %>
          <div class="card card-liquid shadow-sm mb-4">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 class="h5 mb-0">
                  <i class="bi bi-people text-liquid-warning me-2"></i>
                  Adhésions enfants
                  <span class="badge bg-liquid-warning text-dark ms-2"><%= children_memberships.count %></span>
                </h3>
                      <%= link_to new_membership_path(type: 'child'), class: "btn btn-sm btn-liquid-warning", data: { turbo: false } do %>
                      <i class="bi bi-person-plus me-1"></i>Ajouter
                    <% end %>
              </div>

              <!-- ESSAIS GRATUITS ACTIFS (en haut) -->
              <% if children_trial.any? %>
                <div class="alert alert-info payment-alert-improved mb-4" style="background: linear-gradient(135deg, rgba(13, 110, 253, 0.1) 0%, rgba(13, 110, 253, 0.05) 100%); border: 1px solid rgba(13, 110, 253, 0.3);">
                  <h4 class="h6 mb-3">
                    <i class="bi bi-gift-fill me-2"></i>
                    <%= children_trial.count %> ESSAI(S) GRATUIT(S) ACTIF(S)
                  </h4>
                  <p class="small mb-3 text-muted">
                    Ces enfants peuvent utiliser leur essai gratuit pour s'inscrire à une initiation.
                  </p>
                  
                  <div class="mb-3">
                    <% children_trial.each do |membership| %>
                      <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-info border-opacity-25">
                        <div>
                          <strong><%= membership.child_full_name %></strong>
                          <small class="text-muted d-block">
                            <i class="bi bi-info-circle me-1"></i>
                            Peut s'inscrire a une initiations sans adhésion
                          </small>
                          <small class="text-muted d-block mt-1">
                            <i class="bi bi-tag me-1"></i>
                            Cotisation : <%= number_to_currency(membership.amount_cents / 100.0, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
                          </small>
                        </div>
                        <span class="badge bg-info text-white">🎁 Essai gratuit</span>
                      </div>
                    <% end %>
                  </div>
                  
                  <div class="d-flex gap-2 flex-wrap">
                    <% children_trial.each do |membership| %>
                      <%= button_to upgrade_membership_path(membership),
                          method: :patch,
                          class: "btn btn-primary btn-sm",
                          data: { 
                            turbo: false,
                            confirm: "Payer la cotisation de #{membership.child_full_name} (#{number_to_currency(membership.amount_cents / 100.0, unit: "€", separator: ",", delimiter: " ", format: "%n %u")}) ? Vous serez redirigé vers le paiement."
                          } do %>
                        <i class="bi bi-credit-card me-1"></i>
                        Payer la cotisation de <%= membership.child_first_name %>
                      <% end %>
                    <% end %>
                  </div>
                </div>
                
                <!-- Mini cards enfants trial -->
                <div class="row g-2 mb-4">
                  <% children_trial.each do |membership| %>
                    <div class="col-12 col-md-6">
                      <%= render partial: 'child_mini_card', locals: { membership: membership, is_pending: false } %>
                    </div>
                  <% end %>
                </div>
              <% end %>

              <!-- ENFANTS EN ATTENTE DE PAIEMENT (en bas) -->
              <% if children_pending.any? %>
                <div class="alert alert-warning payment-alert-improved <%= 'mt-4' if children_trial.any? %>">
                  <h4 class="h6 mb-3">
                    <i class="bi bi-pin-map me-2"></i>
                    <%= children_pending.count %> ENFANT(S) EN ATTENTE DE PAIEMENT
                  </h4>
                  
                  <div class="mb-3">
                    <% children_pending.each do |membership| %>
                      <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <div>
                          <strong><%= membership.child_full_name %></strong>
                          <small class="text-muted d-block">
                            <%= number_to_currency(membership.total_amount_cents / 100.0, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
                          </small>
                        </div>
                        <span class="badge bg-warning text-dark">⏳ <%= t("statuses.membership.pending") %></span>
                      </div>
                    <% end %>
                  </div>
                  
                  <div class="d-flex justify-content-between align-items-center mb-3 p-2 rounded" style="background: var(--liquid-glass-bg); border: 1px solid var(--card-border-color);">
                    <strong>Total :</strong>
                    <strong class="fs-5">
                      <%= number_to_currency(children_pending.sum(&:total_amount_cents) / 100.0, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
                    </strong>
                  </div>
                  
                  <%= form_with url: create_multiple_payments_memberships_path, method: :post, local: true, data: { turbo: false }, class: "mb-2" do |f| %>
                    <% children_pending.each do |membership| %>
                      <%= f.hidden_field "membership_ids[]", value: membership.id %>
                    <% end %>
                    <%= f.submit "🔐 Payer avec HelloAsso →", class: "btn btn-warning btn-lg w-100 mb-2" %>
                  <% end %>
                  
                  <div class="d-flex gap-3 justify-content-center">
                    <small class="text-muted">
                      <i class="bi bi-shield-check me-1"></i>Paiement sécurisé
                    </small>
                    <small class="text-muted">
                      <i class="bi bi-envelope me-1"></i>Reçu par email
                    </small>
                  </div>
                </div>
                
                <!-- Mini cards enfants pending -->
                <div class="row g-2 mb-3">
                  <% children_pending.each do |membership| %>
                    <div class="col-12 col-md-6">
                      <%= render partial: 'child_mini_card', locals: { membership: membership, is_pending: true } %>
                    </div>
                  <% end %>
                </div>
              <% end %>

              <!-- Enfants payés/actifs -->
              <% if children_paid.any? %>
                <% if children_trial.any? || children_pending.any? %>
                  <hr class="my-4">
                  <h4 class="h6 mb-3 text-muted">Payées / Actives</h4>
                <% end %>
                
                <div class="row g-2">
                  <% children_paid.each do |membership| %>
                    <div class="col-12 col-md-6">
                      <%= render partial: 'child_mini_card', locals: { membership: membership, is_pending: false } %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- HISTORIQUE (adhésions expirées) -->
        <% if expired_memberships.any? %>
          <div class="card card-liquid shadow-sm">
            <div class="card-body">
              <h3 class="h6 mb-3">
                <i class="bi bi-clock-history text-muted me-2"></i>
                Historique
              </h3>
              <% expired_memberships.each do |membership| %>
                <div class="membership-history-item">
                  <div>
                    <strong>
                      <% if membership.is_child_membership? %>
                        <%= membership.child_full_name %> - Saison <%= membership.season %>
                      <% else %>
                        Saison <%= membership.season %>
                      <% end %>
                    </strong>
                    <small class="text-muted d-block">
                      ✓ Payée (<%= number_to_currency(membership.amount_cents / 100.0, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>)
                      - Expirée le <%= l(membership.end_date, format: :short) if membership.end_date %>
                    </small>
                  </div>
                  <% if membership.is_child_membership? %>
                    <% 
                      # Vérifier si l'enfant a déjà une adhésion pour la saison courante
                      current_season = Membership.current_season_name
                      has_current_season_membership = current_user.memberships.children
                        .where(season: current_season,
                               child_first_name: membership.child_first_name,
                               child_last_name: membership.child_last_name,
                               child_date_of_birth: membership.child_date_of_birth)
                        .where(status: [Membership.statuses[:active], Membership.statuses[:pending], Membership.statuses[:trial]])
                        .exists?
                    %>
                    <% unless has_current_season_membership %>
                      <%= button_to renew_membership_path(membership), method: :post, class: "btn btn-sm btn-success", data: { turbo: false, confirm: "Renouveler l'adhésion de #{membership.child_full_name} pour la saison #{Membership.current_season_name} ?" } do %>
                        <i class="bi bi-arrow-repeat me-1"></i>Réadhérer
                      <% end %>
                    <% end %>
                  <% else %>
                    <%= link_to new_membership_path(type: 'adult', renew_from: membership.id), class: "btn btn-sm btn-success" do %>
                      <i class="bi bi-arrow-repeat me-1"></i>Renouveler
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
