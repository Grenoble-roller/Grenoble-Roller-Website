<div class="image-upload-zone" 
     data-controller="image-upload"
     data-image-upload-max-size-value="5242880"
     data-image-upload-accepted-types-value="image/jpeg,image/png,image/webp">
  
  <!-- Zone de drop -->
  <div class="drop-zone border-2 border-dashed rounded p-5 text-center mb-4"
       data-image-upload-target="dropZone"
       data-action="dragover->image-upload#handleDragOver 
                    drop->image-upload#handleDrop 
                    dragleave->image-upload#handleDragLeave">
    <i class="bi bi-cloud-upload display-4 text-muted mb-3"></i>
    <p class="mb-2">
      <strong>Glissez-déposez vos images ici</strong>
    </p>
    <p class="text-muted small mb-3">
      ou cliquez sur le bouton ci-dessous
    </p>
    <%= form.file_field :image, 
        multiple: false,
        accept: "image/jpeg,image/png,image/webp",
        class: "d-none",
        id: "product_image_input",
        data: { 
          image_upload_target: "fileInput",
          action: "change->image-upload#handleFiles"
        } %>
    <button type="button" 
            class="btn btn-outline-primary"
            data-action="click->image-upload#triggerFileInput">
      <i class="bi bi-upload me-2"></i>Sélectionner un fichier
    </button>
    <p class="text-muted small mt-3 mb-0">
      Import recommandé : <strong>master 4:5</strong> (1080×1350), sujet centré, texte loin des bords.
      Le site affiche en <strong>square 1:1</strong>. Formats acceptés : JPG, PNG, WebP (max 5MB).
    </p>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <div class="card border-0 bg-light h-100">
        <div class="card-header bg-transparent">
          <h6 class="mb-0">Aperçu master (fichier entier)</h6>
        </div>
        <div class="card-body d-flex align-items-center justify-content-center" style="min-height: 220px;">
          <% if product&.persisted? && product.image&.attached? %>
            <%= image_tag product.image,
                data: { image_upload_target: "masterImage" },
                class: "img-fluid rounded",
                style: "max-height: 200px; width: auto; object-fit: contain;" %>
          <% else %>
            <div data-image-upload-target="masterPlaceholder" class="text-muted small text-center">
              <i class="bi bi-image me-1"></i>Aucune image sélectionnée
            </div>
            <img data-image-upload-target="masterImage"
                class="img-fluid rounded d-none"
                style="max-height: 200px; width: auto; object-fit: contain;"
                alt="">
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card border-0 bg-light h-100">
        <div class="card-header bg-transparent">
          <h6 class="mb-0">Aperçu square (1:1)</h6>
        </div>
        <div class="card-body p-0">
          <div class="position-relative rounded overflow-hidden" style="aspect-ratio: 1 / 1; background: #eee;">
            <% if product&.persisted? && product.image&.attached? %>
              <%= image_tag product.image.variant(resize_to_fill: [800, 800], format: :webp, saver: { quality: 82 }),
                  data: { image_upload_target: "squareImage" },
                  class: "position-absolute top-0 start-0 w-100 h-100",
                  style: "object-fit: cover; object-position: center;" %>
            <% else %>
              <div data-image-upload-target="squarePlaceholder" class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                <span class="text-muted small">Prévisualisation 1:1</span>
              </div>
              <img data-image-upload-target="squareImage"
                  class="position-absolute top-0 start-0 w-100 h-100 d-none"
                  style="object-fit: cover; object-position: center;"
                  alt="">
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Preview de l'image actuelle -->
  <% if product&.persisted? && product.image&.attached? %>
    <div class="image-preview-current mb-4">
      <h6 class="mb-3">Image actuelle</h6>
      <div class="position-relative d-inline-block">
        <%= image_tag product.image, class: "img-thumbnail", style: "max-height: 200px; max-width: 200px; object-fit: cover;" %>
        <button type="button"
                class="btn btn-sm btn-danger position-absolute top-0 end-0 m-2"
                data-action="click->image-upload#removeCurrentImage"
                title="Supprimer l'image">
          <i class="bi bi-trash"></i>
        </button>
      </div>
    </div>
  <% end %>

  <!-- Preview des nouvelles images uploadées -->
  <div class="image-preview-grid mt-4" data-image-upload-target="previewGrid" style="display: none;">
    <h6 class="mb-3">Nouvelles images</h6>
    <div class="row g-3" data-image-upload-target="previewContainer">
      <!-- Images seront ajoutées ici dynamiquement -->
    </div>
  </div>
</div>

