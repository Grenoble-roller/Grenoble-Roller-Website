<%= form_with model: [:admin_panel, @carousel], 
    local: true, 
    multipart: true, 
    class: "carousel-form",
    data: { controller: "carousel-form" } do |f| %>
  
  <% if @carousel.errors.any? %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <h5 class="alert-heading">
        <i class="bi bi-exclamation-triangle me-2"></i>Erreurs à corriger
      </h5>
      <ul class="mb-0">
        <% @carousel.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">
        <%= @carousel.persisted? ? "Modifier le slide" : "Nouveau slide" %>
      </h1>
      <p class="text-muted mb-0">
        <% if @carousel.persisted? %>
          <i class="bi bi-clock-history me-1"></i>
          Dernière modification : <%= time_ago_in_words(@carousel.updated_at) %>
        <% else %>
          Remplissez les informations ci-dessous
        <% end %>
      </p>
    </div>
    <div class="btn-group">
      <%= link_to admin_panel_homepage_carousels_path, class: "btn btn-outline-secondary" do %>
        <i class="bi bi-arrow-left me-1"></i>Retour
      <% end %>
      <%= f.submit "Enregistrer", class: "btn btn-liquid-primary" %>
    </div>
  </div>

  <div class="row">
    <!-- Formulaire principal -->
    <div class="col-lg-8">
      <div class="card card-liquid rounded-liquid shadow-liquid mb-4">
        <div class="card-header">
          <h5 class="mb-0">Informations</h5>
        </div>
        <div class="card-body">
          <!-- Titre (administration) -->
          <div class="mb-3">
            <%= f.label :title, "Titre *", class: "form-label fw-semibold" %>
            <%= f.text_field :title, 
                class: "form-control form-control-liquid", 
                placeholder: "Ex. Événement à la une",
                required: true %>
            <div class="form-text">Utilisé uniquement en administration (liste, breadcrumb). Le texte du bandeau doit être intégré à l’image.</div>
          </div>

          <!-- Description (optionnel) -->
          <div class="mb-3">
            <%= f.label :subtitle, "Description", class: "form-label fw-semibold" %>
            <%= f.text_field :subtitle, 
                class: "form-control form-control-liquid", 
                placeholder: "Indications optionnelles pour les bénévoles" %>
            <div class="form-text">Optionnel. Notes internes, non affichées sur le site.</div>
          </div>

          <!-- Lien URL -->
          <div class="mb-3">
            <%= f.label :link_url, "Lien URL", class: "form-label fw-semibold" %>
            <%= f.url_field :link_url, 
                class: "form-control form-control-liquid", 
                placeholder: "https://..." %>
            <div class="form-text">Optionnel. URL de destination au clic sur le slide.</div>
          </div>

          <!-- Position -->
          <div class="mb-3">
            <%= f.label :position, "Position", class: "form-label fw-semibold" %>
            <%= f.number_field :position, 
                class: "form-control form-control-liquid", 
                min: 1,
                value: @carousel.position || (HomepageCarousel.maximum(:position) || 0) + 1 %>
            <div class="form-text">Ordre d'affichage dans le carrousel (1 = premier)</div>
          </div>

          <!-- Dates -->
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <%= f.label :published_at, "Date de publication", class: "form-label fw-semibold" %>
              <%= f.datetime_local_field :published_at, 
                  class: "form-control form-control-liquid",
                  value: @carousel.published_at&.strftime("%Y-%m-%dT%H:%M") %>
              <div class="form-text">Optionnel. Utilisée uniquement si « Publié » n'est pas coché : le slide n'apparaît qu'à partir de cette date.</div>
            </div>
            <div class="col-md-6">
              <%= f.label :expires_at, "Date d'expiration", class: "form-label fw-semibold" %>
              <%= f.datetime_local_field :expires_at, 
                  class: "form-control form-control-liquid",
                  value: @carousel.expires_at&.strftime("%Y-%m-%dT%H:%M") %>
              <div class="form-text">Laisser vide pour ne pas expirer</div>
            </div>
          </div>

          <!-- Publié -->
          <div class="mb-3">
            <div class="form-check">
              <%= f.check_box :published, class: "form-check-input" %>
              <%= f.label :published, "Publié", class: "form-check-label" %>
            </div>
            <div class="form-text"><strong>Coché</strong> = publication forcée : le slide est visible immédiatement (jusqu'à la date d'expiration si renseignée). <strong>Non coché</strong> = visibilité uniquement entre la date de publication et la date d'expiration.</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Image -->
    <div class="col-lg-4">
      <div class="card card-liquid rounded-liquid shadow-liquid mb-4">
        <div class="card-header">
          <h5 class="mb-0">Image *</h5>
        </div>
        <div class="card-body">
          <div class="mb-3 carousel-form-image-preview" style="min-height: 200px;">
            <% if @carousel.image.attached? %>
              <%= image_tag @carousel.image,
                  data: { carousel_form_target: "imagePreview" },
                  class: "img-fluid rounded w-100",
                  style: "max-height: 280px; width: auto; object-fit: contain; display: block; margin: 0 auto;" %>
            <% else %>
              <div data-carousel-form-target="imagePreviewPlaceholder" class="bg-light d-flex align-items-center justify-content-center rounded" style="min-height: 200px;">
                <i class="bi bi-image fs-1 text-muted"></i>
              </div>
              <img data-carousel-form-target="imagePreview"
                  class="img-fluid rounded w-100 d-none"
                  style="max-height: 280px; width: auto; object-fit: contain; display: block; margin: 0 auto;"
                  alt="">
            <% end %>
          </div>

          <div class="mb-3">
            <%= f.file_field :image, 
                class: "form-control form-control-liquid",
                accept: "image/*",
                required: @carousel.new_record?,
                data: { carousel_form_target: "fileInput" } %>
            <div class="form-text">
              Bannière annonces 16:9 (recommandé 1920×1080 ; le site affiche en 1200×675). Contenu centré, idéalement &lt; 20 % de texte dans l’image.<br>
              Formats : JPG, PNG, WebP. L’aperçu ci-dessous affiche le rendu réel avant publication.
            </div>
          </div>

          <% if @carousel.image.attached? %>
            <div class="alert alert-info mb-0">
              <i class="bi bi-info-circle me-2"></i>
              Une image est déjà attachée. Choisir un nouveau fichier pour la remplacer (aperçu immédiat).
            </div>
          <% end %>
        </div>
      </div>

      <!-- Aperçu au ratio réel 16:9 -->
      <div class="card card-liquid rounded-liquid shadow-liquid">
        <div class="card-header">
          <h5 class="mb-0">Aperçu bannière (16:9)</h5>
        </div>
        <div class="card-body p-0">
          <div class="carousel-form-ratio-preview rounded overflow-hidden position-relative" style="aspect-ratio: 16/9; background: #eee;">
            <% if @carousel.image.attached? %>
              <%= image_tag @carousel.image.variant(resize_to_fill: [1200, 675]),
                  data: { carousel_form_target: "ratioPreview" },
                  class: "w-100 h-100 position-absolute top-0 start-0",
                  style: "object-fit: cover; object-position: center;" %>
            <% else %>
              <div data-carousel-form-target="ratioPreviewPlaceholder" class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                <span class="text-muted small"><i class="bi bi-image me-1"></i>Choisir un fichier pour voir l’aperçu</span>
              </div>
              <img data-carousel-form-target="ratioPreview"
                  class="position-absolute top-0 start-0 w-100 h-100 d-none"
                  style="object-fit: cover; object-position: center;"
                  alt="">
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
