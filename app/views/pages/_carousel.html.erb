<% 
  # Récupérer les slides actifs et publiés
  carousels = HomepageCarousel.active.ordered
%>

<% if carousels.any? %>
  <div id="homepageCarousel" class="carousel slide carousel-fade" data-controller="carousel" data-bs-ride="carousel" data-bs-interval="5000" data-bs-pause="false">
    <!-- Indicateurs -->
    <% if carousels.count > 1 %>
      <div class="carousel-indicators">
        <% carousels.each_with_index do |carousel, index| %>
          <button type="button" 
                  data-bs-target="#homepageCarousel" 
                  data-bs-slide-to="<%= index %>" 
                  class="<%= 'active' if index == 0 %>"
                  aria-current="<%= 'true' if index == 0 %>"
                  aria-label="Slide <%= index + 1 %>"></button>
        <% end %>
      </div>
    <% end %>

    <!-- Slides -->
    <div class="carousel-inner">
      <% carousels.each_with_index do |carousel, index| %>
        <div class="carousel-item <%= 'active' if index == 0 %>">
          <% if carousel.image.attached? %>
            <% 
              # Variant hero pour le carrousel (ratio 3.2:1, max 1920x600)
              image_variant = carousel.image.variant(resize_to_limit: [1920, 600])
            %>
            <%= image_tag image_variant, 
                class: "d-block w-100", 
                alt: carousel.title,
                style: "height: 60vh; min-height: 400px; object-fit: cover;" %>
          <% end %>
          
          <!-- Caption -->
          <div class="carousel-caption d-none d-md-block">
            <div class="container">
              <div class="row justify-content-center">
                <div class="col-lg-8 text-center">
                  <h2 class="display-4 fw-bold mb-3 text-white">
                    <%= carousel.title %>
                  </h2>
                  <% if carousel.subtitle.present? %>
                    <p class="lead mb-4 text-white">
                      <%= carousel.subtitle %>
                    </p>
                  <% end %>
                  <% if carousel.link_url.present? %>
                    <%= link_to carousel.link_url, 
                        class: "btn btn-liquid-primary btn-lg", 
                        target: carousel.link_url.start_with?('http') ? '_blank' : nil,
                        rel: carousel.link_url.start_with?('http') ? 'noopener noreferrer' : nil do %>
                      <i class="bi bi-arrow-right me-2"></i>
                      En savoir plus
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Contrôles -->
    <% if carousels.count > 1 %>
      <button class="carousel-control-prev" type="button" data-bs-target="#homepageCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Précédent</span>
      </button>
      <button class="carousel-control-next" type="button" data-bs-target="#homepageCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Suivant</span>
      </button>
    <% end %>
  </div>
<% else %>
  <!-- Fallback : Hero banner par défaut si aucun carrousel -->
  <div class="banner-hero mb-0">
    <div class="banner-overlay"></div>
    <div class="banner-content">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-12 col-lg-8 text-center">
            <i class="bi bi-roller-skate banner-icon mb-3"></i>
            <h1 class="banner-title mb-4">
              La communauté <br>Roller Grenobloise !
            </h1>
            <p class="banner-subtitle mb-4">
              Découvrez nos événements, partagez vos sorties et connectez-vous avec d'autres riders à Grenoble
            </p>
            <div class="banner-actions">
              <%= link_to events_path, class: "btn btn-liquid-primary btn-lg" do %>
                <i class="bi bi-calendar-event me-2"></i>
                Découvrir les événements
              <% end %>
              <% if !user_signed_in? %>
                <%= link_to new_user_session_path, class: "btn btn-outline-light btn-lg" do %>
                  <i class="bi bi-box-arrow-in-right me-2"></i>
                  Connexion
                <% end %>
                <%= link_to new_user_registration_path, class: "btn btn-outline-light btn-lg" do %>
                  <i class="bi bi-person-plus me-2"></i>
                  S'inscrire
                <% end %>
              <% elsif !current_user.has_active_membership? %>
                <%= link_to new_membership_path(type: 'adult'), class: "btn btn-outline-light btn-lg" do %>
                  <i class="bi bi-person-badge me-2" aria-hidden="true"></i>
                  Adhérer
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
