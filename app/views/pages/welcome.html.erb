<% content_for :title, "Bienvenue - Grenoble Roller" %>
<% content_for :description, "Bienvenue sur Grenoble Roller ! Découvrez les prochaines étapes pour profiter pleinement de votre compte." %>

<section class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-10">
      <!-- Header de bienvenue -->
      <div class="text-center mb-5">
        <div class="mb-4">
          <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
        </div>
        <h1 class="display-4 fw-bold mb-3">
          <% if @user %>
            Bienvenue <%= @user.first_name.presence || "dans la communauté" %> ! 🎉
          <% else %>
            Bienvenue dans la communauté ! 🎉
          <% end %>
        </h1>
        <p class="lead text-muted">
          <% if @user %>
            Votre compte est créé ! Vous faites maintenant partie de la communauté Roller Grenobloise. 
            Découvrez nos randonnées urbaines, nos cours d'initiation et nos événements à thème.
          <% else %>
            Votre compte est créé ! Vous faites maintenant partie de la communauté Roller Grenobloise. 
            Découvrez nos randonnées urbaines, nos cours d'initiation et nos événements à thème.
          <% end %>
        </p>
      </div>

          <!-- Prochaines étapes -->
          <% if @user %>
            <div class="row g-4 mb-5">
              <% @next_steps.each_with_index do |step, index| %>
                <div class="col-12 col-md-6 col-lg-4">
                  <div class="card card-liquid h-100 <%= 'border-success' if step[:completed] %>">
                    <div class="card-body p-4">
                      <div class="d-flex align-items-start mb-3">
                        <div class="flex-shrink-0">
                          <% if step[:completed] %>
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 2rem;"></i>
                          <% else %>
                            <i class="bi <%= step[:icon] %> text-liquid-primary" style="font-size: 2rem;"></i>
                          <% end %>
                        </div>
                        <div class="flex-grow-1 ms-3">
                          <h3 class="h5 fw-bold mb-2">
                            <%= step[:title] %>
                            <% if step[:completed] %>
                              <span class="badge bg-success ms-2">Terminé</span>
                            <% else %>
                              <span class="badge bg-warning ms-2">À faire</span>
                            <% end %>
                          </h3>
                          <p class="text-muted small mb-3"><%= step[:description] %></p>
                          <% unless step[:completed] %>
                            <%= link_to step[:action_path], class: "btn btn-sm btn-outline-primary" do %>
                              <%= step[:action] %>
                              <i class="bi bi-arrow-right ms-1" aria-hidden="true"></i>
                            <% end %>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <!-- Message pour utilisateur non connecté -->
            <div class="alert alert-info mb-4" role="alert">
              <div class="d-flex align-items-start">
                <i class="bi bi-info-circle-fill me-3 mt-1" style="font-size: 1.5rem;"></i>
                <div class="flex-grow-1">
                  <h4 class="alert-heading h5 mb-2">Activez votre compte</h4>
                  <p class="mb-3">
                    Un email de confirmation vous attend dans votre boîte mail. 
                    Cliquez sur le lien pour activer votre compte, puis connectez-vous pour découvrir nos randonnées urbaines et nos événements à thème !
                  </p>
                  <div class="d-flex gap-2 flex-wrap">
                    <%= link_to new_user_confirmation_path, class: "btn btn-info" do %>
                      <i class="bi bi-envelope me-2" aria-hidden="true"></i>
                      Vérifier mes emails
                    <% end %>
                    <%= link_to new_user_session_path, class: "btn btn-primary" do %>
                      <i class="bi bi-box-arrow-in-right me-2" aria-hidden="true"></i>
                      Se connecter
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

      <!-- Message de confirmation email -->
      <% if @user && !@user.confirmed? %>
        <div class="alert alert-info mb-4" role="alert">
          <div class="d-flex align-items-start">
            <i class="bi bi-info-circle-fill me-3 mt-1" style="font-size: 1.5rem;"></i>
            <div class="flex-grow-1">
              <h4 class="alert-heading h5 mb-2">Confirmez votre adresse email</h4>
              <p class="mb-3">
                Un email vous attend à <strong><%= @user.email %></strong>. 
                Cliquez sur le lien pour activer votre compte et découvrir nos randonnées urbaines, nos cours d'initiation et nos événements à thème !
              </p>
              <div class="d-flex gap-2 flex-wrap">
                <%= link_to new_user_confirmation_path(email: @user.email), class: "btn btn-info" do %>
                  <i class="bi bi-envelope me-2" aria-hidden="true"></i>
                  Renvoyer l'email de confirmation
                <% end %>
                <%= link_to new_user_session_path, class: "btn btn-outline-secondary" do %>
                  <i class="bi bi-box-arrow-in-right me-2" aria-hidden="true"></i>
                  Se connecter
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Actions rapides -->
      <div class="card card-liquid mb-4">
        <div class="card-body p-4">
          <h2 class="h5 fw-bold mb-3">
            <i class="bi bi-lightning-charge text-liquid-primary me-2" aria-hidden="true"></i>
            Commencez votre aventure
          </h2>
          <div class="d-flex gap-2 flex-wrap">
            <%= link_to events_path, class: "btn btn-liquid-primary" do %>
              <i class="bi bi-calendar-event me-2" aria-hidden="true"></i>
              Découvrir les événements
            <% end %>
            <% if @user %>
              <%= link_to new_membership_path(type: 'adult'), class: "btn btn-outline-primary" do %>
                <i class="bi bi-person-badge me-2" aria-hidden="true"></i>
                Rejoindre l'association
              <% end %>
            <% end %>
            <%= link_to about_path, class: "btn btn-outline-secondary" do %>
              <i class="bi bi-heart me-2" aria-hidden="true"></i>
              En savoir plus sur l'association
            <% end %>
          </div>
        </div>
      </div>

      <!-- Retour à l'accueil -->
      <div class="text-center">
        <%= link_to root_path, class: "btn btn-link text-decoration-none" do %>
          <i class="bi bi-arrow-left me-2" aria-hidden="true"></i>
          Retour à l'accueil
        <% end %>
      </div>
    </div>
  </div>
</section>
