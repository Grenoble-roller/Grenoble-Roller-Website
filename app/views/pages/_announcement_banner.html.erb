<%
  carousels = HomepageCarousel.active.ordered
%>

<% if carousels.any? %>
  <section class="announcement-banner-section py-0">
    <div class="container container-lg">
      <div id="announcementCarousel"
           class="carousel slide carousel-fade announcement-banner-carousel"
           data-controller="carousel"
           data-carousel-autoplay-value="true"
           data-bs-interval="4000"
           role="region"
           aria-label="Annonces importantes">
        <% if carousels.count > 1 %>
          <div class="carousel-indicators">
            <% carousels.each_with_index do |carousel, index| %>
              <button type="button"
                      data-bs-target="#announcementCarousel"
                      data-bs-slide-to="<%= index %>"
                      class="<%= 'active' if index == 0 %>"
                      aria-current="<%= 'true' if index == 0 %>"
                      aria-label="Slide <%= index + 1 %> : <%= carousel.title %>"></button>
            <% end %>
          </div>
        <% end %>

        <div class="carousel-inner">
          <% carousels.each_with_index do |carousel, index| %>
            <div class="carousel-item <%= 'active' if index == 0 %>">
              <% if carousel.image.attached? %>
                <% image_variant = carousel.image.variant(resize_to_fill: [1200, 675]) %>
                <% if carousel.link_url.present? %>
                  <%= link_to carousel.link_url,
                      class: "d-block w-100 h-100 announcement-banner-link",
                      target: carousel.link_url.start_with?('http') ? '_blank' : nil,
                      rel: carousel.link_url.start_with?('http') ? 'noopener noreferrer' : nil,
                      aria: { label: "Voir la suite" } do %>
                    <%= image_tag image_variant,
                        class: "d-block w-100 h-100 announcement-banner-img",
                        alt: carousel.title %>
                  <% end %>
                <% else %>
                  <%= image_tag image_variant,
                      class: "d-block w-100 h-100 announcement-banner-img",
                      alt: carousel.title %>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>

        <% if carousels.count > 1 %>
          <button class="carousel-control-prev" type="button" data-bs-target="#announcementCarousel" data-bs-slide="prev" aria-label="Slide précédente">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#announcementCarousel" data-bs-slide="next" aria-label="Slide suivante">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
          </button>
        <% end %>
      </div>
    </div>
  </section>
<% end %>
