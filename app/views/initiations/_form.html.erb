<div class="row justify-content-center">
  <div class="col-12 col-lg-8">
    <div class="card card-liquid rounded-liquid shadow-liquid auth-form auth-form--wide">
      <div class="card-body p-4 p-lg-5">
        <div class="text-center mb-4">
          <i class="bi bi-book fs-1 text-liquid-primary"></i>
          <h3 class="mt-2"><%= initiation.persisted? ? 'Modifier l\'initiation' : 'Créer une initiation' %></h3>
          <p class="text-muted small">
            Complétez les informations nécessaires pour publier votre séance d'initiation.
          </p>
        </div>

        <% if initiation.errors.any? %>
          <div class="alert alert-liquid-danger rounded-liquid mb-4">
            <h4 class="h6 fw-semibold mb-2">
              <%= pluralize(initiation.errors.count, "erreur") %> empêchent l'enregistrement :
            </h4>
            <ul class="mb-0 small">
              <% initiation.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_with(model: initiation, url: initiation.persisted? ? initiation_path(initiation) : initiations_path, html: { class: 'row g-3', multipart: true, data: { controller: 'media-preview' } }) do |f| %>
          <div class="col-12">
            <%= f.label :title, "Titre", class: "form-label" %>
            <%= f.text_field :title, class: "form-control form-control-liquid", required: true, maxlength: 140, placeholder: "Initiation Roller - Samedi 6 septembre 2025" %>
          </div>

          <!-- Le statut n'est pas modifiable par l'instructeur, seulement par les modérateurs -->
          <% if can_moderate? %>
            <div class="col-12 col-md-6">
              <%= f.label :status, "Statut", class: "form-label" %>
              <%= f.select :status, 
                  Event::Initiation.statuses.keys.map { |status| 
                    label = case status
                            when 'draft' then 'En attente de validation'
                            when 'published' then 'Publié'
                            when 'canceled' then 'Annulé'
                            else status.humanize
                            end
                    [label, status]
                  }, 
                  {}, 
                  class: "form-select form-select-liquid" %>
            </div>
          <% else %>
            <%= f.hidden_field :status, value: 'draft' %>
            <div class="col-12">
              <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                <strong>En attente de validation</strong> : Votre initiation sera soumise à validation par un modérateur avant d'être publiée.
              </div>
            </div>
          <% end %>

          <div class="col-12 col-md-6">
            <%= f.label :start_at, "Date et heure de début", class: "form-label" %>
            <%= f.datetime_field :start_at, class: "form-control form-control-liquid", required: true %>
          </div>

          <div class="col-12 col-md-6">
            <%= f.label :duration_min, "Durée (minutes)", class: "form-label" %>
            <%= f.number_field :duration_min, class: "form-control form-control-liquid", min: 60, step: 5, required: true, value: initiation.duration_min || 105 %>
          </div>

          <div class="col-12 col-md-6">
            <%= f.label :max_participants, "Nombre maximum de participants", class: "form-label" %>
            <%= f.number_field :max_participants, class: "form-control form-control-liquid", min: 1, step: 1, required: true, value: initiation.max_participants || 30 %>
            <div class="form-text">
              <i class="bi bi-info-circle me-1"></i>
              Nombre total de places disponibles (adhérents + non-adhérents si option activée)
            </div>
          </div>

          <div class="col-12 col-md-6">
            <%= f.label :level, "Niveau", class: "form-label" %>
            <%= f.select :level, 
                options_for_select([
                  ['Débutant', 'beginner'],
                  ['Intermédiaire', 'intermediate'],
                  ['Confirmé', 'advanced'],
                  ['Tous niveaux', 'all_levels']
                ], initiation.level || 'beginner'),
                { include_blank: false },
                class: "form-select form-select-liquid" %>
          </div>

          <!-- Option pour limiter les places non-adhérents -->
          <div class="col-12">
            <div class="card card-body bg-body-secondary border-0 p-3 gps-coordinates-card">
              <div class="form-check form-switch mb-3">
                <%= f.check_box :allow_non_member_discovery, 
                    { class: "form-check-input", id: "allow_non_member_discovery", 
                      data: { bs_toggle: "collapse", bs_target: "#nonMemberDiscoveryOptions" } }, 
                    true, false %>
                <%= f.label :allow_non_member_discovery, 
                    "Limiter les places pour les non-adhérents (initiation découverte)", 
                    class: "form-check-label fw-semibold", 
                    for: "allow_non_member_discovery" %>
              </div>
              <div class="collapse<%= ' show' if initiation.allow_non_member_discovery? %>" id="nonMemberDiscoveryOptions">
                <div class="mb-2">
                  <div class="d-flex align-items-center justify-content-between gap-3 mb-2">
                    <%= f.label :non_member_discovery_slots, 
                        "Nombre de places réservées aux non-adhérents", 
                        class: "form-label small mb-0" %>
                    <%= f.number_field :non_member_discovery_slots, 
                        class: "form-control form-control-sm form-control-liquid", 
                        style: "max-width: 100px;",
                        min: 0, 
                        step: 1, 
                        value: initiation.non_member_discovery_slots || 0,
                        placeholder: "Ex: 5" %>
                  </div>
                  <div class="form-text small">
                    <i class="bi bi-info-circle me-1"></i>
                    Si activé : les adhérents utilisent les places restantes (<strong>max_participants - places non-adhérents</strong>). 
                    Si désactivé : tout le monde peut s'inscrire librement dans les <strong>max_participants</strong> places.
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-12">
            <%= f.label :location_text, "Lieu / Point de rendez-vous", class: "form-label" do %>
              Lieu / Point de rendez-vous <span class="text-danger">*</span>
            <% end %>
            <%= f.text_field :location_text, 
                class: "form-control form-control-liquid", 
                maxlength: 255, 
                required: true, 
                value: initiation.location_text || "Gymnase Ampère, 74 Rue Anatole France, 38100 Grenoble",
                placeholder: "Gymnase Ampère, 74 Rue Anatole France, 38100 Grenoble",
                aria: { describedby: 'locationHelp' } %>
          </div>

          <!-- Coordonnées GPS optionnelles (collapsed par défaut) -->
          <div class="col-12">
            <button class="btn btn-link text-decoration-none p-0" 
                    type="button" 
                    data-bs-toggle="collapse" 
                    data-bs-target="#gpsCoordinates"
                    aria-expanded="<%= initiation.has_gps_coordinates? ? 'true' : 'false' %>"
                    aria-controls="gpsCoordinates">
              <i class="bi bi-geo-alt me-1"></i>
              <span class="text-muted">(Optionnel) Ajouter les coordonnées GPS précises</span>
              <i class="bi bi-chevron-<%= initiation.has_gps_coordinates? ? 'up' : 'down' %> ms-1"></i>
            </button>
            
            <div class="collapse<%= ' show' if initiation.has_gps_coordinates? %> mt-2" id="gpsCoordinates">
              <div class="card card-body bg-body-secondary gps-coordinates-card">
                
                <div class="row g-2">
                  <div class="col-md-6">
                    <%= f.label :meeting_lat, "Latitude", class: "form-label small" %>
                    <%= f.number_field :meeting_lat, 
                        class: "form-control form-control-sm", 
                        step: "any",
                        value: initiation.meeting_lat,
                        placeholder: "45.1732" %>
                  </div>
                  <div class="col-md-6">
                    <%= f.label :meeting_lng, "Longitude", class: "form-label small" %>
                    <%= f.number_field :meeting_lng, 
                        class: "form-control form-control-sm", 
                        step: "any",
                        value: initiation.meeting_lng,
                        placeholder: "5.7057" %>
                  </div>
                </div>
                
                <div class="mt-2">
                  <a href="https://www.google.com/maps" 
                     target="_blank" 
                     rel="noopener noreferrer"
                     class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-map me-1"></i>
                    Trouver les coordonnées sur Google Maps
                  </a>
                </div>
              </div>
            </div>
          </div>

          <div class="col-12">
            <%= f.label :cover_image, "Image de couverture", class: "form-label" %>
            <%= f.file_field :cover_image,
                accept: "image/*",
                class: "form-control form-control-liquid",
                required: !initiation.persisted? || !initiation.cover_image.attached?,
                data: { media_preview_target: "fileInput" } %>
            <div class="form-text">
              <i class="bi bi-info-circle me-1"></i>
              <strong>Obligatoire</strong> pour une nouvelle annonce (une image est requise). Formats : JPG, PNG, WebP.
              <strong>Ratios compatibles</strong> : 16:9 (paysage) ou 4:5 (portrait) ; d’autres ratios fonctionnent aussi. Le site génère les dérivés <strong>carré 1:1</strong> (listes) et <strong>bannière 16:9</strong> (bandeau) — privilégiez un sujet centré, texte loin des bords.
            </div>
          </div>

          <div class="col-12">
            <div class="row g-3">
              <div class="col-md-4">
                <div class="card card-liquid border-0 h-100">
                  <div class="card-header">
                    <h6 class="mb-0">Aperçu master (fichier entier)</h6>
                  </div>
                  <div class="card-body d-flex align-items-center justify-content-center" style="min-height: 220px;">
                    <% if initiation.persisted? && initiation.cover_image.attached? %>
                      <%= image_tag initiation.cover_image,
                          data: { media_preview_target: "masterImage" },
                          class: "img-fluid rounded",
                          style: "max-height: 200px; width: auto; object-fit: contain;" %>
                    <% else %>
                      <div data-media-preview-target="masterPlaceholder" class="text-muted small text-center">
                        <i class="bi bi-image me-1"></i>Choisir un fichier pour prévisualiser
                      </div>
                      <img data-media-preview-target="masterImage"
                          class="img-fluid rounded d-none"
                          style="max-height: 200px; width: auto; object-fit: contain;"
                          alt="">
                    <% end %>
                  </div>
                </div>
              </div>

              <div class="col-md-4">
                <div class="card card-liquid border-0 h-100">
                  <div class="card-header">
                    <h6 class="mb-0">Aperçu square (1:1)</h6>
                  </div>
                  <div class="card-body p-0">
                    <div class="position-relative rounded overflow-hidden" style="aspect-ratio: 1 / 1; background: #eee;">
                      <% if initiation.persisted? && initiation.cover_image.attached? %>
                        <%= image_tag initiation.cover_image_square,
                            data: { media_preview_target: "surfaceImage" },
                            class: "position-absolute top-0 start-0 w-100 h-100",
                            style: "object-fit: cover; object-position: center;" %>
                      <% else %>
                        <div data-media-preview-target="surfacePlaceholder" class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                          <span class="text-muted small">Prévisualisation 1:1</span>
                        </div>
                        <img data-media-preview-target="surfaceImage"
                            class="position-absolute top-0 start-0 w-100 h-100 d-none"
                            style="object-fit: cover; object-position: center;"
                            alt="">
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>

              <div class="col-md-4">
                <div class="card card-liquid border-0 h-100">
                  <div class="card-header">
                    <h6 class="mb-0">Aperçu banner (16:9)</h6>
                  </div>
                  <div class="card-body p-0">
                    <div class="position-relative rounded overflow-hidden" style="aspect-ratio: 16 / 9; background: #eee;">
                      <% if initiation.persisted? && initiation.cover_image.attached? %>
                        <%= image_tag initiation.cover_image_banner,
                            data: { media_preview_target: "surfaceImage" },
                            class: "position-absolute top-0 start-0 w-100 h-100",
                            style: "object-fit: cover; object-position: center;" %>
                      <% else %>
                        <div data-media-preview-target="surfacePlaceholder" class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                          <span class="text-muted small">Prévisualisation 16:9</span>
                        </div>
                        <img data-media-preview-target="surfaceImage"
                            class="position-absolute top-0 start-0 w-100 h-100 d-none"
                            style="object-fit: cover; object-position: center;"
                            alt="">
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-12">
            <%= f.label :description, "Description détaillée", class: "form-label" do %>
              Description détaillée <span class="text-danger">*</span>
            <% end %>
            <%= f.text_area :description, class: "form-control form-control-liquid", rows: 5, required: true, minlength: 10, placeholder: "Décrivez la séance d'initiation, le matériel nécessaire, les prérequis..." %>
            <div class="form-text">
              <i class="bi bi-info-circle me-1"></i>
              Minimum 10 caractères
            </div>
          </div>

          <!-- Champs cachés pour initiations -->
          <%= f.hidden_field :type, value: 'Event::Initiation' %>
          <%= f.hidden_field :currency, value: "EUR" %>
          <%= f.hidden_field :price_cents, value: 0 %>
          <%= f.hidden_field :distance_km, value: 0 %>

          <div class="col-12 mt-3 d-grid gap-2">
            <%= f.submit (initiation.persisted? ? "Mettre à jour l'initiation" : "Créer l'initiation"), class: "btn btn-liquid-primary btn-lg w-100" %>
            <%= link_to 'Annuler', initiations_path, class: "btn btn-outline-secondary w-100" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<% if initiation.persisted? && policy(initiation).destroy? %>
  <div class="text-center mt-3">
    <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal">
      <i class="bi bi-trash me-2"></i>Supprimer l'initiation
    </button>
  </div>

  <div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title h5" id="confirmDeleteModalLabel">Supprimer l'initiation</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
        </div>
        <div class="modal-body">
          <p class="mb-0">
            Cette action est irréversible. Confirmez-vous la suppression de
            <strong><%= initiation.title %></strong> ?
          </p>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
          <%= button_to initiation_path(initiation), method: :delete, form: { data: { turbo: true } }, class: "btn btn-danger" do %>
            <i class="bi bi-trash me-2"></i>Oui, supprimer
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

