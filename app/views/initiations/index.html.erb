<% content_for :title, 'Initiations Roller - Grenoble Roller' %>
<% content_for :description, "Cours d'initiation au roller tous les samedis matin de 10h15 à 12h00 au Gymnase Ampère. Gratuit après adhésion, essai gratuit disponible." %>

<section class="banner-page mb-4">
  <div class="banner-overlay"></div>
  <div class="banner-content">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 text-center">
          <i class="bi bi-book-fill banner-icon-small mb-2" aria-hidden="true"></i>
          <h1 class="banner-title-page mb-3">Initiations Roller</h1>
          <p class="banner-subtitle-page mb-4">
            Cours d'initiation pour les adhérents et les enfants (essai gratuit possible)
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="container pb-5">
  <!-- Infos statiques -->
  <div class="card card-liquid shadow-sm mb-4">
    <div class="card-body p-4">
      <h2 class="h5 mb-3">
        <i class="bi bi-info-circle text-liquid-primary me-2" aria-hidden="true"></i>
        Informations pratiques
      </h2>
      <div class="row g-3">
        <div class="col-12 col-md-6">
          <p class="mb-2">
            <i class="bi bi-people text-liquid-primary me-2" aria-hidden="true"></i>
            <strong>Public :</strong> Adhérents, enfants dès 6 ans (adulte obligatoire)
          </p>
        </div>
        <div class="col-12 col-md-6">
          <p class="mb-0">
            <i class="bi bi-gift text-liquid-primary me-2" aria-hidden="true"></i>
            <strong>Essai gratuit :</strong> 1 essai sans adhésion
          </p>
        </div>
      </div>
    </div>
  </div>

  <%# Tableau de statut désactivé temporairement %>
  <% if false && user_signed_in? %>
    <%= render 'initiations/status_table' %>
  <% end %>

  <!-- Liste des prochaines initiations -->
  <div id="initiations-upcoming" class="mb-5">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between mb-3">
      <div>
        <h2 class="h2 fw-bold mb-1">
          <i class="bi bi-calendar-event me-2" aria-hidden="true"></i>
          Prochaines séances
        </h2>
        <p class="text-body-secondary mb-0">
          Les prochaines initiations disponibles.
        </p>
      </div>
      <div class="d-flex align-items-center gap-3">
        <% if user_signed_in? && policy(Event::Initiation.new).create? %>
          <%= link_to new_initiation_path, class: "btn btn-liquid-primary" do %>
            <i class="bi bi-plus-circle me-2" aria-hidden="true"></i>
            Créer une initiation
          <% end %>
        <% end %>
        <span class="badge badge-liquid-primary fs-6">
          <%= pluralize(@upcoming_initiations.size, "séance", "séances") %>
        </span>
      </div>
    </div>

    <% if @upcoming_initiations.any? %>
      <div class="event-grid">
        <div class="row g-4">
          <% @upcoming_initiations.each_with_index do |initiation, index| %>
            <%= render 'initiations/initiation_card_modern',
                       initiation: initiation,
                       is_first: (index == 0) %>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="card card-liquid border-liquid shadow-sm">
        <div class="card-body p-4 p-md-5 text-center">
          <i class="bi bi-mortarboard fs-1 text-muted mb-3 d-block" aria-hidden="true"></i>
          <h3 class="h5 fw-bold mb-3">Aucune séance d'initiation à venir</h3>
          
          <% if user_signed_in? %>
            <% if policy(Event::Initiation.new).create? %>
              <p class="text-body-secondary mb-4">
                Il n'y a pas encore de séance d'initiation planifiée. En tant qu'administrateur, vous pouvez créer la première séance !
              </p>
              <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
                <%= link_to new_initiation_path, class: "btn btn-liquid-primary" do %>
                  <i class="bi bi-plus-circle me-2" aria-hidden="true"></i>Créer une séance d'initiation
                <% end %>
                <%= link_to events_path, class: "btn btn-outline-primary" do %>
                  <i class="bi bi-calendar-event me-2" aria-hidden="true"></i>Voir les événements
                <% end %>
              </div>
            <% else %>
              <p class="text-body-secondary mb-4">
                Aucune séance d'initiation n'est prévue pour le moment. Revenez bientôt pour découvrir les prochaines séances !
              </p>
              <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
                <%= link_to events_path, class: "btn btn-liquid-primary" do %>
                  <i class="bi bi-calendar-event me-2" aria-hidden="true"></i>Voir les événements
                <% end %>
                <%= link_to about_path, class: "btn btn-outline-secondary" do %>
                  <i class="bi bi-info-circle me-2" aria-hidden="true"></i>En savoir plus sur l'association
                <% end %>
              </div>
            <% end %>
          <% else %>
            <p class="text-body-secondary mb-4">
              Aucune séance d'initiation n'est prévue pour le moment. Connectez-vous pour être informé des prochaines séances !
            </p>
            <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
              <%= link_to new_user_session_path, class: "btn btn-liquid-primary" do %>
                <i class="bi bi-box-arrow-in-right me-2" aria-hidden="true"></i>Se connecter
              <% end %>
              <%= link_to events_path, class: "btn btn-outline-primary" do %>
                <i class="bi bi-calendar-event me-2" aria-hidden="true"></i>Voir les événements
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Initiations passées -->
  <div id="initiations-past">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between mb-3">
      <div>
        <h2 class="h2 fw-bold mb-1">
          <i class="bi bi-archive me-2" aria-hidden="true"></i>
          Séances passées
        </h2>
        <p class="text-body-secondary mb-0">
          Un aperçu des dernières initiations organisées.
        </p>
      </div>
      <% if @pagy_past.count > 0 %>
        <span class="badge badge-liquid-secondary fs-6">
          <%= pluralize(@pagy_past.count, "séance", "séances") %>
        </span>
      <% end %>
    </div>

    <% if @past_initiations.any? %>
      <!-- Tableau des initiations passées -->
      <div class="card card-liquid">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Titre</th>
                  <th>Niveau</th>
                  <th>Participants</th>
                  <th>Statut</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% @past_initiations.each do |initiation| %>
                  <tr>
                    <td data-label="Date">
                      <div class="d-flex flex-column">
                        <span class="fw-semibold"><%= initiation.start_at.strftime("%d/%m/%Y") %></span>
                        <small class="text-muted"><%= initiation.start_at.strftime("%H:%M") %></small>
                      </div>
                    </td>
                    <td data-label="Titre">
                      <div class="d-flex align-items-center">
                        <% if initiation.cover_image.attached? %>
                          <%= image_tag rails_representation_path(initiation.cover_image_banner), class: "rounded me-2", style: "width: 71px; height: 40px; object-fit: cover;", alt: initiation.title %>
                        <% end %>
                        <span class="fw-semibold"><%= initiation.title %></span>
                      </div>
                    </td>
                    <td data-label="Niveau">
                      <% case initiation.level %>
                      <% when "beginner" %>
                        <span class="badge bg-info">Débutant</span>
                      <% when "intermediate" %>
                        <span class="badge bg-primary">Intermédiaire</span>
                      <% when "advanced" %>
                        <span class="badge bg-warning">Confirmé</span>
                      <% when "all_levels" %>
                        <span class="badge bg-secondary">Tous niveaux</span>
                      <% end %>
                    </td>
                    <td data-label="Participants">
                      <%= initiation.attendances_count %> / <%= initiation.max_participants %>
                    </td>
                    <td data-label="Statut">
                      <% if initiation.canceled? %>
                        <span class="badge bg-danger">Annulé</span>
                      <% else %>
                        <span class="badge bg-success">Terminé</span>
                      <% end %>
                    </td>
                    <td data-label="Actions">
                      <%= link_to initiation_path(initiation), class: "btn btn-sm btn-outline-primary" do %>
                        <i class="bi bi-eye me-1" aria-hidden="true"></i>Voir
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
      <!-- Pagination initiations passées -->
      <% if @pagy_past.pages > 1 %>
        <div class="mt-4 d-flex justify-content-center">
          <%== pagy_bootstrap_nav(@pagy_past) %>
        </div>
      <% end %>
    <% else %>
      <div class="card card-liquid border-liquid shadow-sm">
        <div class="card-body p-4 p-md-5 text-center">
          <i class="bi bi-archive fs-1 text-muted mb-3 d-block" aria-hidden="true"></i>
          <h3 class="h5 fw-bold mb-3">Aucune séance passée</h3>
          <p class="text-body-secondary mb-4">
            Les initiations passées apparaîtront ici une fois qu'elles auront eu lieu.
          </p>
          <% if user_signed_in? && policy(Event::Initiation.new).create? %>
            <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
              <%= link_to new_initiation_path, class: "btn btn-outline-primary" do %>
                <i class="bi bi-plus-circle me-2" aria-hidden="true"></i>Créer une initiation
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>

