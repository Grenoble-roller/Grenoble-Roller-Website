<% content_for :title, 'Mes sorties' %>

<section class="container py-4 py-lg-5">
  <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
    <div>
      <h1 class="display-5 fw-semibold mb-1">Mes sorties</h1>
      <p class="text-body-secondary mb-0">
        Retrouvez ici toutes les sorties auxquelles vous êtes inscrit(e). Gérez vos inscriptions en un clic.
      </p>
    </div>
    <%= link_to events_path, class: 'btn btn-outline-primary' do %>
      <i class="bi bi-calendar-event me-2"></i>Voir toutes les sorties
    <% end %>
  </div>

  <!-- Filtres -->
  <% if current_user.attendances.active.exists? || params[:reminder].present? %>
    <div class="card card-liquid mb-4">
      <div class="card-body p-3 p-md-4">
        <%= form_with url: attendances_path, method: :get, local: true, class: "row g-3 align-items-end", data: { turbo: false } do |f| %>
          <!-- Filtre Rappel -->
          <div class="col-12 col-md-4">
            <%= f.label :reminder, "Rappel", class: "form-label fw-semibold small mb-1" %>
            <%= f.select :reminder,
                options_for_select([
                  ["Tous", ""],
                  ["Rappel activé", "enabled"],
                  ["Rappel désactivé", "disabled"]
                ], params[:reminder]),
                {},
                { class: "form-select form-select-sm" } %>
          </div>

          <!-- Boutons -->
          <div class="col-12 col-md-4">
            <div class="d-flex gap-2">
              <%= f.submit "Filtrer", class: "btn btn-liquid-primary btn-sm flex-grow-1" %>
              <% if params[:reminder].present? %>
                <%= link_to attendances_path, class: "btn btn-outline-secondary btn-sm" do %>
                  <i class="bi bi-x-lg" aria-hidden="true"></i>
                <% end %>
              <% end %>
            </div>
          </div>

          <!-- Conserver les paramètres de pagination si présents -->
          <%= hidden_field_tag :page_upcoming, params[:page_upcoming] if params[:page_upcoming].present? %>
          <%= hidden_field_tag :page_past, params[:page_past] if params[:page_past].present? %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @upcoming_attendances.any? || @past_attendances.any? %>
    <!-- Section À venir -->
    <% if @upcoming_attendances && @upcoming_attendances.any? %>
      <div id="attendances-upcoming" class="mb-5">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between mb-3">
          <div>
            <h2 class="h2 fw-bold mb-1"><i class="bi bi-stars me-2" aria-hidden="true"></i>À venir</h2>
            <p class="text-body-secondary mb-0">
              Vos prochaines sorties roller.
            </p>
          </div>
          <span class="badge badge-liquid-primary fs-6"><%= pluralize(@pagy_upcoming.count, "sortie", "sorties") %></span>
        </div>

        <div class="event-grid">
          <div class="row g-4">
            <% @upcoming_attendances.each do |attendance| %>
              <%= render 'events/event_card',
                         event: attendance.event,
                         attendance: attendance,
                         render_signup_button: true,
                         current_user: current_user %>
            <% end %>
          </div>
        </div>
        
        <!-- Pagination événements à venir -->
        <% if @pagy_upcoming.pages > 1 %>
          <div class="mt-4 d-flex justify-content-center">
            <%== pagy_bootstrap_nav(@pagy_upcoming) %>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Section Passés -->
    <% if @past_attendances && @past_attendances.any? %>
      <div id="attendances-past">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between mb-3">
          <div>
            <h2 class="h2 fw-bold mb-1"><i class="bi bi-archive me-2" aria-hidden="true"></i>Sorties passées</h2>
            <p class="text-body-secondary mb-0">
              Historique de vos participations.
            </p>
          </div>
          <span class="badge badge-liquid-secondary fs-6"><%= pluralize(@pagy_past.count, "sortie", "sorties") %></span>
        </div>

        <div class="event-grid">
          <div class="row g-4">
            <% @past_attendances.each do |attendance| %>
              <%= render 'events/event_card',
                         event: attendance.event,
                         attendance: attendance,
                         render_signup_button: false,
                         current_user: current_user,
                         past: true %>
            <% end %>
          </div>
        </div>
        
        <!-- Pagination événements passés -->
        <% if @pagy_past.pages > 1 %>
          <div class="mt-4 d-flex justify-content-center">
            <%== pagy_bootstrap_nav(@pagy_past) %>
          </div>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div class="alert alert-info border-0 shadow-sm">
      <i class="bi bi-info-circle me-2"></i>Vous n'êtes inscrit(e) à aucune sortie pour le moment.
      <%= link_to 'Découvrir les événements', events_path, class: 'alert-link ms-1' %>
    </div>
  <% end %>
</section>

