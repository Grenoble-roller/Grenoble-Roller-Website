<%# Partial partagé pour le modal de suppression d'un événement (réutilise le layout générique) %>
<%# Variables attendues: event (peut être Event ou Event::Initiation) %>

<% if policy(event).destroy? %>
  <%= render "shared/confirm_destroy_modal",
      modal_id: "confirmDeleteModalShow",
      title: "Supprimer #{event.is_a?(Event::Initiation) ? "l'initiation" : "l'événement"}",
      message: "Cette action est définitive. Souhaitez-vous supprimer #{content_tag(:strong, event.title)} ?".html_safe,
      destroy_path: event_path_for(event) %>
<% end %>

