<%# Modal de confirmation de suppression (réutilisable) %>
<%# Variables : modal_id, title, message, destroy_path, button_label (optionnel, défaut "Oui, supprimer") %>
<% modal_id = local_assigns[:modal_id] || "confirmDestroyModal" %>
<% title = local_assigns[:title] || "Confirmer la suppression" %>
<% message = local_assigns[:message] || "Cette action est irréversible. Confirmez-vous la suppression ?" %>
<% button_label = local_assigns[:button_label] || "Oui, supprimer" %>

<div class="modal fade" id="<%= modal_id %>" tabindex="-1" aria-labelledby="<%= modal_id %>Label" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title h5" id="<%= modal_id %>Label"><%= title %></h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>
      <div class="modal-body">
        <p class="mb-0"><%= message %></p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <%= button_to destroy_path, method: :delete, form: { data: { turbo: true } }, class: "btn btn-danger" do %>
          <i class="bi bi-trash me-2" aria-hidden="true"></i><%= button_label %>
        <% end %>
      </div>
    </div>
  </div>
</div>
