#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# If running the rails server, choose a DB boot strategy.
# Match explicit exec-form CMD: $1=./bin/rails $2=server (additional args e.g. -b may follow).
if [ "${1:-}" = "./bin/rails" ] && [ "${2:-}" = "server" ]; then
  DB_BOOT_TASK="${DB_BOOT_TASK:-}"
  if [ -z "$DB_BOOT_TASK" ]; then
    # Safe default: production-like deploys should NOT auto-seed on first boot.
    if [ "${RAILS_ENV:-}" = "production" ] || [ "${APP_ENV:-}" = "production" ] || [ "${DEPLOY_ENV:-}" = "production" ]; then
      DB_BOOT_TASK="migrate"
    else
      DB_BOOT_TASK="prepare"
    fi
  fi

  case "$DB_BOOT_TASK" in
    none)
      echo "Skipping DB boot task (DB_BOOT_TASK=none)"
      ;;
    migrate)
      echo "Running DB migration bootstrap (DB_BOOT_TASK=migrate)..."
      ./bin/rails db:migrate || echo "Warning: db:migrate failed, continuing anyway..."
      ;;
    prepare)
      echo "Preparing database (DB_BOOT_TASK=prepare)..."
      ./bin/rails db:prepare || {
        echo "Warning: db:prepare failed, trying db:migrate..."
        ./bin/rails db:migrate || echo "Warning: db:migrate also failed, continuing anyway..."
      }
      ;;
    *)
      echo "Warning: unknown DB_BOOT_TASK='$DB_BOOT_TASK' (expected: prepare|migrate|none). Falling back to db:migrate."
      ./bin/rails db:migrate || echo "Warning: db:migrate failed, continuing anyway..."
      ;;
  esac

  # Solid Queue in Puma needs DB tables. If they are missing (fresh DB, or an earlier boot where
  # db:prepare/migrate failed silently), run migrations. Under `set -e`, use `if` so a non-zero
  # exit from the check does not abort the script before db:migrate runs.
  if [ "${SOLID_QUEUE_IN_PUMA:-}" = "true" ] && compgen -G "db/migrate/*solid_queue*" > /dev/null 2>&1; then
    if [ "${RAILS_ENV:-}" = "production" ] || [ "${RAILS_ENV:-}" = "staging" ] || \
       [ "${APP_ENV:-}" = "staging" ] || [ "${DEPLOY_ENV:-}" = "staging" ] || [ "${DEPLOY_ENV:-}" = "production" ]; then
      if ! ./bin/rails runner 'exit(ActiveRecord::Base.connection.table_exists?(:solid_queue_processes) ? 0 : 1)'; then
        echo "solid_queue_processes missing — running db:migrate..."
        ./bin/rails db:migrate
      fi
    fi
  fi

  # Auto-create S3 bucket if missing (production/staging only; no-op on disk storage)
  if [ "${RAILS_ENV}" == "production" ] || [ "${RAILS_ENV}" == "staging" ] || [ "${APP_ENV}" == "staging" ] || [ "${DEPLOY_ENV}" == "staging" ] || [ "${DEPLOY_ENV}" == "production" ]; then
    echo "Ensuring S3 bucket exists..."
    bundle exec rake storage:ensure_bucket || echo "Warning: S3 bucket setup failed, continuing..."
  fi
fi

# Force CSS rebuild in development environment on startup
# This ensures CSS is up-to-date after git pull
# Note: This runs AFTER volume mount, so it compiles CSS in the mounted directory
if [ "${RAILS_ENV}" == "development" ] && [ -f "package.json" ]; then
  echo "Preparing development environment..."
  
  # Check if gems need to be updated (when Gemfile.lock changes after rebuild or git pull)
  # This solves the issue where volume bundle persists old gems even after image rebuild
  if [ -f "Gemfile.lock" ]; then
    GEMFILE_LOCK_CHECKSUM=$(md5sum Gemfile.lock | cut -d' ' -f1)
    BUNDLE_CHECKSUM_FILE="${BUNDLE_PATH:-/rails/vendor/bundle}/.gemfile_lock_checksum"
    
    if [ ! -f "$BUNDLE_CHECKSUM_FILE" ] || [ "$(cat "$BUNDLE_CHECKSUM_FILE" 2>/dev/null)" != "$GEMFILE_LOCK_CHECKSUM" ]; then
      echo "Gemfile.lock has changed or gems are missing. Installing/updating gems..."
      bundle install || echo "Warning: bundle install failed, continuing anyway..."
      echo "$GEMFILE_LOCK_CHECKSUM" > "$BUNDLE_CHECKSUM_FILE"
      echo "Gems updated successfully."
    else
      echo "Gems are up-to-date."
    fi
  fi
  
  # Install node_modules if they don't exist (first run or volume is empty)
  if [ ! -d "node_modules" ] || [ -z "$(ls -A node_modules 2>/dev/null)" ]; then
    echo "Installing node_modules (this may take a moment on first run)..."
    PATH="/usr/local/node/bin:$PATH" npm install || echo "Warning: npm install failed, continuing anyway..."
  fi
  
  echo "Rebuilding CSS to ensure latest changes are applied..."
  # Ensure builds directory exists
  mkdir -p app/assets/builds/fonts
  # Build CSS (application + ActiveAdmin) with proper SASS_PATH and npm path
  ACTIVEADMIN_STYLES_PATH=$(bundle exec ruby -e 'spec = Gem.loaded_specs["activeadmin"]; print spec&.full_gem_path ? spec.full_gem_path + "/app/assets/stylesheets" : ""')
  if [ -n "$ACTIVEADMIN_STYLES_PATH" ]; then
    export SASS_PATH="node_modules:${ACTIVEADMIN_STYLES_PATH}"
  else
    echo "Warning: Could not resolve ActiveAdmin styles path, fallback to node_modules only."
    export SASS_PATH="node_modules"
  fi
  PATH="/usr/local/node/bin:$PATH" npm run build:css || echo "Warning: CSS rebuild failed, continuing anyway..."
  
  # Ensure Bootstrap Icons fonts are present
  if [ ! -f "app/assets/builds/fonts/bootstrap-icons.woff2" ]; then
    echo "Warning: Bootstrap Icons fonts not found, attempting to copy manually..."
    mkdir -p app/assets/builds/fonts
    cp -r node_modules/bootstrap-icons/font/fonts/*.woff* app/assets/builds/fonts/ 2>/dev/null || echo "Warning: Could not copy Bootstrap Icons fonts"
  fi
fi

# Run Supercronic in the background for cron in production/staging
if [ "${RAILS_ENV}" == "production" ] || [ "${RAILS_ENV}" == "staging" ] || [ "${APP_ENV}" == "staging" ] || [ "${DEPLOY_ENV}" == "staging" ] || [ "${DEPLOY_ENV}" == "production" ]; then
  if [ -f "/rails/config/crontab" ]; then
    echo "Starting Supercronic for cron jobs..."
    # Ensure log directory exists and permissions are OK
    mkdir -p /rails/log
    touch /rails/log/cron.log 2>/dev/null || true
    # Supercronic logs to stdout/stderr; task output may go to log/cron.log
    supercronic /rails/config/crontab &
    SUPERICRONIC_PID=$!
    echo "Supercronic started in background (PID: $SUPERICRONIC_PID)"
  else
    echo "Warning: /rails/config/crontab not found, skipping cron jobs"
  fi
fi

exec "$@"
